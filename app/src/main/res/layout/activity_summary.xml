<?xml version="1.0" encoding="utf-8"?>
<!-- 1. BACKGROUND: A crisp, modern slate-gray/blue that makes the white cards POP -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 2. SCREEN TITLE: Dark navy text instead of basic black feels much more premium -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:text="Walk Complete! 🎉"
        android:textAlignment="center"
        android:textColor="#0F172A"
        android:textSize="34sp"
        android:textStyle="bold" />

    <!-- 3. THE STATS CARD: Added a subtle border (stroke) and increased the shadow (elevation) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp">

            <!-- Distance Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Sleek slate-gray label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISTANCE"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- VIBRANT ROYAL BLUE for Distance -->
                <TextView
                    android:id="@+id/tvFinalDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0.00 KM"
                    android:textColor="#2563EB"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- A subtle divider line between the stats -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:background="#E2E8F0" />

            <!-- Time Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <!-- Sleek slate-gray label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DURATION"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- VIBRANT EMERALD GREEN for Time -->
                <TextView
                    android:id="@+id/tvFinalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="00:00"
                    android:textColor="#10B981"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 4. THE MAP BOX: Matches the premium styling of the stats card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="24dp"
        android:layout_weight="1"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/summaryMap"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </com.google.android.material.card.MaterialCardView>

    <!-- 5. SAVE BUTTON: Vibrant Royal Blue to match the distance stat -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveWalk"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="8dp"
        android:text="SAVE TO JOURNAL"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#2563EB"
        app:cornerRadius="16dp"
        app:elevation="4dp" />

    <!-- 6. DISCARD BUTTON: A slightly softer, modern red -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDiscardWalk"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DISCARD WALK"
        android:textColor="#EF4444"
        android:textStyle="bold" />

    <!-- 7. GO BACK BUTTON: Clean and sleek -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSummaryBack"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="32dp"
        android:text="GO BACK"
        android:textColor="#0F172A"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="#0F172A"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp" />

</LinearLayout>